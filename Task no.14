    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "marks=np.random.randint(30,101,(10,5))\n",
        "\n",
        "print(\"Marks:\\n\",marks)\n",
        "\n",
        "total=np.sum(marks,axis=1)\n",
        "average=np.mean(marks,axis=1)\n",
        "\n",
        "print(\"Total Marks:\",total)\n",
        "print(\"Average Marks:\",average)\n",
        "\n",
        "highest=np.argmax(total)\n",
        "lowest=np.argmin(total)\n",
        "\n",
        "print(\"Top Student Index:\",highest)\n",
        "print(\"Lowest Student Index:\",lowest)\n",
        "\n",
        "print(\"Class Mean:\",np.mean(marks))\n",
        "print(\"Standard Deviation:\",np.std(marks))\n",
        "\n",
        "top3=np.argsort(total)[-3:]\n",
        "\n",
        "print(\"Top 3 Student Indices:\",top3)\n",
        "print(\"Marks of Top 3 Students:\\n\",marks[top3])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
