        "print(\"Maximum Value:\",np.max(arr))\n",
        "print(\"Index of Maximum:\", np.argmax(arr))\n",
        "print(\"Sum:\",np.sum(arr))\n",
        "print(\"Mean:\",np.mean(arr))\n",
        "print(\"Standard Deviation:\",np.std(arr))"
