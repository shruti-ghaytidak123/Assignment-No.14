    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "arr = np.random.randint(1,101,(5,5))\n",
        "print(\"Matrix\\n:\", arr)\n",
        "print(\"Diagonal:\", np.diag(arr))\n",
        "print(\"Greater than 50:\", arr[arr>50])\n",
        "\n",
        "arr[arr>30]=0\n",
        "\n",
        "print(\"Modified Matrix:\\n\", arr)"
      ],
